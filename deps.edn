;; kami-mangaka-qa — work-agnostic manga QA / perception axes + geometry.
;;
;; 退役 Python runtime (lg_mangaka の jump_benchmark_qa、v10 世代) が持っていた
;; 有用資産のうち **可搬な正本** — QA 軸レジストリ (heuristic 13 軸 + Jump 8 軸 +
;; composeScene3d 由来 rubric 8 軸)、v10 score JSON 互換の正規化、VLM 知覚
;; prompt + parser (顔カウント/顔ボックス/コマ境界)、吹き出し×顔の純幾何 QA —
;; を portable .cljc に移植したもの (ADR-2607165100)。
;;
;; 純 cljc — I/O ゼロ。VLM 呼び出しは :vision-fn (fn [prompt image-b64] → map|nil)
;; を注入する langchain-clj 流の host-capability 方式で、JVM でも cljs/nbb でも
;; 同じコードが動く。Python 側のピクセル heuristic (brightness_avg 等) の実装は
;; 移植しない — 計測値は consumer が供給し、本 lib は軸の正本・集約・互換を持つ。
;; Sibling of kami-mangaka-expression / -text / -page / -scene。
{:paths ["src"]

 :deps {org.clojure/clojure {:mvn/version "1.12.0"}}

 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]}

  :lint {:extra-deps {clj-kondo/clj-kondo {:mvn/version "2024.09.27"}}
         :main-opts  ["-m" "clj-kondo.main" "--lint" "src" "test"]}}}
